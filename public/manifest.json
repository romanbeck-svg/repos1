{
  "manifest_version": 3,
  "name": "Mako IQ",
  "description": "Mako IQ analyzes the visible screen and places transparent answer bubbles near detected questions.",
  "version": "0.3.0",
  "key": "",
  "permissions": ["storage", "activeTab", "tabs", "scripting", "sidePanel", "webNavigation"],
  "host_permissions": ["http://127.0.0.1:8787/*", "http://localhost:8787/*"],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "action": {
    "default_title": "Open Mako IQ Workspace",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png"
    }
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "open-mako-iq": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y",
        "mac": "Command+Shift+Y"
      },
      "description": "Open the Mako IQ launcher"
    }
  }
}
