# Build-time default for the active extension UI and background worker.
# Use the backend origin only, with no trailing slash.
# Keep localhost for local dev. Use your Render backend URL here before a hosted extension build,
# or override it later in the extension Options page without rebuilding.
VITE_MAKOIQ_API_BASE_URL=http://localhost:8787

# Hosted example:
# VITE_MAKOIQ_API_BASE_URL=https://your-service.onrender.com
