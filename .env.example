# Build-time default for the active extension UI and background worker.
# Use the backend origin only, with no trailing slash.
# Keep loopback for local-first use. Use your Render backend URL here before a hosted extension build,
# or override it later in the extension Options page without rebuilding.
VITE_MAKOIQ_API_BASE_URL=http://127.0.0.1:8787

# Hosted example:
# VITE_MAKOIQ_API_BASE_URL=https://your-service.onrender.com

# Backend local-first defaults live in backend/.env.example:
# AI_PROVIDER=kimi
# KIMI_BASE_URL=https://api.moonshot.ai/v1
# KIMI_MODEL=kimi-k2.6
# MOONSHOT_API_KEY=
#
# Optional only:
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_MODEL=
