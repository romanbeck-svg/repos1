NODE_ENV=development
HOST=0.0.0.0
PORT=8787
APP_URL=http://localhost:8787
ALLOWED_ORIGINS=http://localhost:5173
ALLOWED_EXTENSION_ORIGINS=chrome-extension://YOUR_EXTENSION_ID
ALLOW_ALL_EXTENSION_ORIGINS=true
ALLOW_ANONYMOUS_USAGE=true

# Required for the active popup analysis flow.
MOONSHOT_API_KEY=
MOONSHOT_MODEL=kimi-k2.5
MOONSHOT_QUICK_MODEL=kimi-k2-turbo-preview
MOONSHOT_REASONING_MODEL=kimi-k2-thinking-turbo
MOONSHOT_VISION_MODEL=kimi-k2.5
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1

# Optional task-route providers.
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Required in production. Keep a strong random value in Render.
JWT_SECRET=replace-with-a-long-random-secret

# Optional Canvas integration.
CANVAS_API_BASE_URL=
CANVAS_API_TOKEN=

# Optional Supabase auth + persistence.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Optional auth / billing redirects.
AUTH_MAGIC_LINK_REDIRECT_URL=http://localhost:8787/auth/callback
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_PORTAL_RETURN_URL=http://localhost:5173
