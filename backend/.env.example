NODE_ENV=development
HOST=127.0.0.1
PORT=8787
APP_URL=http://127.0.0.1:8787
# Local website origin for browser-based dev. Leave blank in Render unless you also have a web app origin to allow.
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ALLOWED_EXTENSION_ORIGINS=chrome-extension://himeagaboplmdgfhajkiipplhoklbooa
ALLOW_ALL_EXTENSION_ORIGINS=false
ALLOW_ANONYMOUS_USAGE=true

# Local-first AI provider. The Chrome extension never calls Kimi directly;
# the local backend calls Moonshot/Kimi with this server-side key.
AI_PROVIDER=kimi
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2.6
MOONSHOT_API_KEY=
MOONSHOT_MODEL=kimi-k2.6
MOONSHOT_QUICK_MODEL=
MOONSHOT_REASONING_MODEL=
MOONSHOT_VISION_MODEL=kimi-k2.6
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1
AI_REQUEST_TIMEOUT_MS=60000

# Optional only. Set AI_PROVIDER=ollama if you intentionally want a local model.
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_MODEL=
OLLAMA_VISION_MODEL=
OLLAMA_KEEP_ALIVE=10m

# Optional task-route providers.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# Required in production. Keep a strong random value in Render.
JWT_SECRET=replace-with-a-long-random-secret

# Optional Canvas integration.
CANVAS_API_BASE_URL=
CANVAS_API_TOKEN=

# Optional Supabase auth + persistence.
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# Optional auth / billing redirects.
AUTH_MAGIC_LINK_REDIRECT_URL=http://localhost:8787/auth/callback
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_PORTAL_RETURN_URL=http://localhost:5173
