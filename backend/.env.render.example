NODE_ENV=production
HOST=0.0.0.0
# Render injects PORT automatically. Do not set it manually in the Render dashboard.
APP_URL=https://YOUR-RENDER-SERVICE.onrender.com
# Optional. Set this only if you also have a browser-based web client origin to allow.
ALLOWED_ORIGINS=
ALLOWED_EXTENSION_ORIGINS=chrome-extension://YOUR_EXTENSION_ID
ALLOW_ALL_EXTENSION_ORIGINS=false
ALLOW_ANONYMOUS_USAGE=true

# Render is optional cloud mode. Normal local-first companion mode uses AI_PROVIDER=kimi too.
AI_PROVIDER=kimi

# Required for hosted cloud page analysis.
MOONSHOT_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2.6
MOONSHOT_MODEL=kimi-k2.6
MOONSHOT_QUICK_MODEL=
MOONSHOT_REASONING_MODEL=
MOONSHOT_VISION_MODEL=kimi-k2.6
MOONSHOT_BASE_URL=https://api.moonshot.ai/v1

# Required in production. Render can generate this for you via render.yaml.
JWT_SECRET=

# Recommended if you use auth redirects.
AUTH_MAGIC_LINK_REDIRECT_URL=https://YOUR-RENDER-SERVICE.onrender.com/auth/callback

# Optional providers / integrations.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
CANVAS_API_BASE_URL=
CANVAS_API_TOKEN=
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_MONTHLY_PRICE_ID=
STRIPE_PORTAL_RETURN_URL=
